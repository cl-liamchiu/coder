{
  "permissions": {
    "allow": ["Read", "Edit", "Write"],
    "deny": ["WebFetch"]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyWrite": ["~"],
      "denyRead": ["~"],
      "allowWrite": ["."],
      "allowRead": ["."]
    },
    "network": {
      "allowedDomains": []
    }
  }
}
