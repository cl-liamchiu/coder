#!/usr/bin/env bash
#
# Sample hook: format-commit-msg
#
# coder calls this script after Claude generates a commit message for
# `coder commit`, BEFORE the commit is created. Replace the body below
# with your own formatting rules (e.g. enforce a project-specific
# footer/trailer, run it through a linter...).
#
# Contract: coder seeds a temp file with JSON and passes its path as $1:
#   { "message": "<raw commit message Claude generated>",
#     "task": {id, ticketId, title, body, status, baseBranch, createdAt, closedAt} }
# Overwrite that same file in place with JSON: { "message": "<final commit
# message>" } (multi-line message is fine). coder reads the file after this
# script exits and parses it — the request and response are both JSON for a
# consistent contract across every hook.
#
# stdin/stdout/stderr are all left connected to the real terminal — coder
# never reads them, so print/prompt freely without any risk of corrupting
# the message.
#
# Requires `jq` to parse the incoming JSON payload and build the JSON
# response.
#
# This hook is optional: if neither .coder/hooks/format-commit-msg nor
# format-commit-msg.js exists, `coder commit` uses Claude's message as-is.

set -euo pipefail

data_file="$1"
payload="$(cat "$data_file")"

message="$(jq -r '.message' <<<"$payload")"
ticket_id="$(jq -r '.task.ticketId // empty' <<<"$payload")"

if [[ -n "$ticket_id" ]]; then
  formatted="$(printf '%s\n\nRefs: %s' "$message" "$ticket_id")"
else
  formatted="$message"
fi

jq -n --arg message "$formatted" '{message: $message}' > "$data_file"
