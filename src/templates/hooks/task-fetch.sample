#!/usr/bin/env bash
#
# Sample hook: task-fetch
#
# coder calls this script to discover the backlog of tasks an AI agent
# can pick up next. Replace the body below with a real integration
# (Linear, Jira, GitHub Issues, a local file, ...).
#
# Contract: stdout MUST be nothing but a JSON array string (the whole
# stream is parsed as one JSON document, so pretty-printed multi-line JSON
# is fine — just don't print anything else to stdout). Each item looks
# like:
#   {
#     "ticketId"?: string | null,
#     "title": string,
#     "body"?: string,
#     "baseBranch": string,
#     "status"?: "TODO" | "IN_PROGRESS" | "IN_REVIEW" | "ON_HOLD" | "REJECTED" | "DONE"
#   }
#
# Progress bars, debug logs, prompts — anything that isn't the data itself —
# must go to stderr instead. `coder fetch` inherits this script's stderr
# straight through to the terminal but only ever reads stdout, so anything
# printed there (even one stray line) breaks JSON parsing and fails the
# whole `coder fetch` run loudly.
#
# status is optional and defaults to TODO when omitted — a source can send
# it explicitly (e.g. ON_HOLD) to pause a task without an agent picking it
# up. It's only honored when inserting a new task, or refreshing a local
# task that's still TODO; anything already IN_PROGRESS/IN_REVIEW/ON_HOLD/
# REJECTED is left alone.
#
# ticketId is used by `coder fetch` to dedupe/update tasks across
# repeated runs. Omit it (or null) if the source has no stable id.
#
# baseBranch is the branch the sandbox should check out before starting
# work on this task (e.g. "main" or "release/2.4") — not a branch name to
# create for the task itself.

set -euo pipefail

echo '[{"ticketId":"EXAMPLE-123","title":"Example task","body":"Replace .coder/hooks/task-fetch with real task-fetching logic.","baseBranch":"main"}]'
